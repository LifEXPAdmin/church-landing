# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/church"

# Basic auth password for /admin/*
ADMIN_PASSWORD="change-me"

# Public site URL for canonical metadata
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Random salt for analytics IP hashing
ANALYTICS_SALT="replace-with-random-string"

# MailerLite API key
MAILERLITE_API_KEY=""

# Optional: group IDs (preferred, fastest)
MAILERLITE_GROUP_ID_BELIEVER=""
MAILERLITE_GROUP_ID_CHURCH=""
MAILERLITE_GROUP_ID_CREATOR=""
MAILERLITE_GROUP_ID_BUSINESS=""
MAILERLITE_GROUP_ID_BUILDER=""

# Optional: group names (fallback if IDs are not set)
MAILERLITE_GROUP_NAME_BELIEVER="Church (User)"
MAILERLITE_GROUP_NAME_CHURCH="Church (Church)"
MAILERLITE_GROUP_NAME_CREATOR="Church (Creator)"
MAILERLITE_GROUP_NAME_BUSINESS="Church (Business)"
MAILERLITE_GROUP_NAME_BUILDER="Church (Builder)"
